generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")

  words          Word[]         @relation("CreatedBy")
  verifiedWords  Word[]         @relation("VerifiedBy")
  activityLogs   ActivityLog[]
  invitesCreated InviteToken[]  @relation("InvitedBy")
  wordLeases     WordLease[]
  imageJobs      ImageJob[]
  notifications  Notification[]

  @@map("users")
}

model InviteToken {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  createdById String    @map("created_by")
  createdBy   User      @relation("InvitedBy", fields: [createdById], references: [id])
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("invite_tokens")
}

model Word {
  id                   String    @id @default(cuid())
  word                 String
  ageGroup             String    @map("age_group")
  // Nullable during the age-group → grade-level migration. Words without a
  // grade tag are treated as "ungraded" by the iOS filter and excluded from
  // grade-scoped pools until a curation batch assigns them.
  gradeLevel           String?   @map("grade_level")
  level                Int
  category             String
  wordLength           Int       @map("word_length")
  hints                Json?
  pronunciation        String?
  pronunciationArpabet String?   @map("pronunciation_arpabet")
  pronunciationRespelling String? @map("pronunciation_respelling")
  partOfSpeech         String?   @map("part_of_speech")
  definition           String?   @db.Text
  exampleSentence      String?   @map("example_sentence") @db.Text
  heartWordExplanation String?   @map("heart_word_explanation") @db.Text
  verified             Boolean   @default(false)
  verifiedAt           DateTime? @map("verified_at")
  verifiedById         String?   @map("verified_by")
  verifiedBy           User?     @relation("VerifiedBy", fields: [verifiedById], references: [id])
  // Soft-delete marker for words the reviewers have decided don't belong
  // in the game. Distinct from `verified=false` (pending) — declined words
  // stay out of the review queue and survive re-imports.
  declined             Boolean   @default(false)
  declinedAt           DateTime? @map("declined_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  createdById          String?   @map("created_by")
  createdBy            User?     @relation("CreatedBy", fields: [createdById], references: [id])
  source               String?

  // Monotonically increasing counter for optimistic concurrency. PATCH
  // callers include the version they read; the server refuses the write
  // (409) if it has moved on, so two concurrent editors can't silently
  // overwrite each other.
  version              Int       @default(0)

  activityLogs ActivityLog[]
  lease        WordLease?
  imageJobs    ImageJob[]

  @@index([category])
  @@index([ageGroup])
  @@index([gradeLevel])
  @@index([verified])
  @@map("words")
}

// Soft lock on a word while a reviewer is actively editing it. The review
// queue filters out words held by other users so two reviewers don't
// duplicate effort. Short TTL (~3 min) keeps things self-healing: if a
// tab dies without releasing, the lease expires and the word re-enters
// circulation automatically.
model WordLease {
  wordId     String   @id @map("word_id")
  word       Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  acquiredAt DateTime @default(now()) @map("acquired_at")
  expiresAt  DateTime @map("expires_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("word_leases")
}

model ActivityLog {
  id        String   @id @default(cuid())
  wordId    String   @map("word_id")
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([wordId])
  @@index([userId])
  @@map("activity_log")
}

// Queue of image-generation requests. The website enqueues a row; a local
// worker process polls /api/image-jobs/next, claims one, runs ComfyUI/Flux,
// uploads to R2, then POSTs /complete. Status flow:
//   pending  → claimed (worker picked it up)
//            → done    (PNG live in R2 at words/<word_id>.png)
//            → failed  (worker error; errorMessage populated)
// Older done/failed rows are kept for audit and "show me the prompt I used
// last time"; the UI only shows the most recent row per word.
model ImageJob {
  id             String    @id @default(cuid())
  wordId         String    @map("word_id")
  word           Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  // Free-form note from the curator: "make it more vibrant", "show two of
  // them", "no humans". Worker appends this to the category-template prompt.
  promptNote     String?   @map("prompt_note") @db.Text
  // Optional style override the curator picked from a dropdown (e.g.
  // "watercolor" / "flat" / "sticker"). Worker maps this to a style suffix.
  style          String?
  status         String    @default("pending") // pending | claimed | done | failed
  errorMessage   String?   @map("error_message") @db.Text
  // What the worker actually fed into Flux — captured so the curator can
  // see it on the panel and decide what to tweak next.
  finalPrompt    String?   @map("final_prompt") @db.Text
  textWarning    String?   @map("text_warning") @db.Text
  requestedById  String    @map("requested_by")
  requestedBy    User      @relation(fields: [requestedById], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at")
  claimedAt      DateTime? @map("claimed_at")
  completedAt    DateTime? @map("completed_at")

  @@index([wordId])
  @@index([status])
  @@map("image_jobs")
}

// In-app notifications. Currently used to tell the curator that an
// ImageJob they kicked off has finished (success or failure). Kept generic
// so other event sources (verification milestones, flag responses) can
// reuse it without a schema change.
model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  // e.g. "image_done" / "image_failed" — used by the bell-icon UI to pick
  // an icon and decide whether to render the link target as a deep link.
  kind      String
  message   String    @db.Text
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@map("notifications")
}
